# =============================================================================
# Echo-Tech Daily — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# Google Gemini API Key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) TTS Voice: Charon (default, male) | Kore | Aoede | Lede
TTS_VOICE_NAME=Charon

# (Optional) Max number of articles to process (default: 10)
MAX_ARTICLES=10

# (Optional) Briefing topic (e.g., AI, Tech, Startups)
TOPIC_NAME=Tech

# (Optional) RSS Feed URL (default: TechCrunch AI)
# Many categories are available on the website
# https://techcrunch.com/category/venture/feed/
# https://techcrunch.com/category/climate/feed/
# https://techcrunch.com/category/robotics/feed/
# ...
RSS_FEED_URL=https://techcrunch.com/category/artificial-intelligence/feed/
