# =============================================================================
# Echo-Tech Daily — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# =============================================================================

# Clé API Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# (Optionnel) Voix TTS : Charon (défaut, masculin) | Kore | Aoede | Lede
TTS_VOICE_NAME=Charon

# (Optionnel) Nombre max d'articles à traiter (défaut: 10)
MAX_ARTICLES=10
